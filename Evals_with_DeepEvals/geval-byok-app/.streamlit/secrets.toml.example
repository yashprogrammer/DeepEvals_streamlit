# Copy to `.streamlit/secrets.toml` and fill real values for LOCAL runs.
# On Streamlit Community Cloud, paste this into Settings → Secrets instead.
# Optional — learners can also paste their own key(s) into the sidebar at runtime.

# Groq (free) — https://console.groq.com/keys — judge + generation (if no 2nd key below).
GROQ_API_KEY = "gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Optional — a key from a DIFFERENT Groq account. If set, generation calls use this key while
# judge calls stay on GROQ_API_KEY, splitting the two across separate rate-limit pools.
GROQ_API_KEY_2 = "gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
